# Wait 60 seconds before connecting using these details, or login to https://console.neo4j.io to validate the Aura Instance is available
NEO4J_URI=neo4j+ssc://instance.databases.neo4j.io
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=
AURA_INSTANCEID=
AURA_INSTANCENAME=

# Add your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key

# Optional: override embedding model used by memory recall/store.
# If your deployment does not support text-embedding-004, try gemini-embedding-001.
GEMINI_EMBED_MODEL=text-embedding-004
# Optional comma-separated fallback order.
GEMINI_EMBED_FALLBACKS=gemini-embedding-001,embedding-001